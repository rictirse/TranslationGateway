<UserControl x:Class="Translation.Gateway.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="600">
    <StackPanel Margin="20">
        <StackPanel Margin="20">

            <GroupBox Header="Connection &amp; Model" Margin="0,0,0,15" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="API Host:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                    <TextBox Text="{Binding ApiHost, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>

                    <TextBlock Text="Model:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                        <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" 
                           Width="150" 
                           HorizontalAlignment="Left" 
                           VerticalAlignment="Center"/>

                        <Button Content="gpt-oss:20b" 
                          Command="{Binding ApplyModelPresetCommand}" 
                          CommandParameter="gpt-oss:20b" 
                          Margin="8,0,0,0" Padding="8,2" />

                        <Button Content="qwen2.5:32b" 
                          Command="{Binding ApplyModelPresetCommand}" 
                          CommandParameter="qwen2.5:32b" 
                          Margin="5,0,0,0" Padding="8,2" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <CheckBox Content="Use Local Model" IsChecked="{Binding IsLocalModel}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
            <GroupBox Header="Translation Engine &amp; Limits" Margin="0,0,0,15" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Max Parallelism:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                    <TextBox Text="{Binding MaxParallelism}" Grid.Row="0" Grid.Column="1" Margin="0,0,10,0">
                        <TextBox.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock Text="同時執行的翻譯任務數" FontWeight="Bold"/>
                                    <TextBlock Text="• 4090 建議值: 4-6"/>
                                    <TextBlock Text="• 5090 建議值: 6-10 (視顯存佔用而定)"/>
                                </StackPanel>
                            </ToolTip>
                        </TextBox.ToolTip>
                    </TextBox>

                    <TextBlock Text="Batch Size:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="2"/>
                    <TextBox Text="{Binding BatchSize}" Grid.Row="0" Grid.Column="3">
                        <TextBox.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock Text="單次 API 請求的字幕條數上限" FontWeight="Bold"/>
                                    <TextBlock Text="• 4090/5090 建議值: 60-100"/>
                                    <TextBlock Text="注意：太高可能會超過模型 Context 導致翻譯品質下降。"/>
                                </StackPanel>
                            </ToolTip>
                        </TextBox.ToolTip>
                    </TextBox>

                    <TextBlock Text="Context Window:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0"/>
                    <TextBox Text="{Binding ContextWindow}" Grid.Row="1" Grid.Column="1" Margin="0,0,10,0" ToolTip="模型支援的最大 Context Token 數 (例如 Qwen2.5 預設 32768/128k)" />

                    <TextBlock Text="Max Output:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="2"/>
                    <TextBox Text="{Binding MaxOutput}" Grid.Row="1" Grid.Column="3" ToolTip="單次 API 請求允許的最大輸出 Token 數 (建議 2048-4096)"/>

                    <TextBlock Text="Temperature:" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0"/>
                    <TextBox Text="{Binding Temperature}" Grid.Row="2" Grid.Column="1" Margin="0,0,10,0" ToolTip="0.0 為最穩定輸出，適合翻譯任務。" />

                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <TextBlock Text="Preset Optimization:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Gray"/>
                        <Button Content="RTX 4090 Optim" 
                          Command="{Binding ApplyHardwarePresetCommand}" 
                          CommandParameter="4090" 
                          Padding="10,4" Margin="0,0,8,0" />
                                                <Button Content="RTX 5090 Optim" 
                          Command="{Binding ApplyHardwarePresetCommand}" 
                          CommandParameter="5090" 
                          Padding="10,4" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Button Content="Save All Settings" 
              Command="{Binding SaveSettingsCommand}" 
              Padding="30,10" 
              HorizontalAlignment="Right" 
              FontSize="14" FontWeight="Bold"
              Background="#0078D7" Foreground="White"/>
        </StackPanel>
    </StackPanel>
</UserControl>